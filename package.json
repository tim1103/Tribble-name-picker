{
  "name": "random",
  "version": "1.3.1",
  "main": "main.js",
  "author": "tim1103",
  "description": "随机点名",
  "license": "GPL-3.0-only",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.tim1103.random",
    "productName": "随机点名",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "portable",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "AppImage",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "Education",
      "icon": "icons",
      "maintainer": "tim1103",
      "description": "A tool for random roll call in the classroom, supporting multiple selection modes.一个用于课堂随机点名的工具，支持多种抽选模式",
      "desktop": {
        "Name": "随机点名",
        "Comment": "课堂随机点名工具",
        "StartupWMClass": "random"
      }
    }
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "sudo-prompt": "^9.2.1"
  }
}